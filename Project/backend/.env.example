# SE-GUARD Backend — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit the real .env file.

# ── Flask ──────────────────────────────────────────────────────────────────
# Secret key used to sign JWT tokens.  Change this to a long random string.
SE_GUARD_SECRET=change-me-to-a-long-random-secret

# ── MongoDB Atlas ──────────────────────────────────────────────────────────
# If not set, the app runs with in-memory storage (data is lost on restart).
# Example Atlas connection string:
#   mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/
MONGO_URI=

# Database name inside the MongoDB instance.
DB_NAME=se_guard_db
